# ============================================================================
# .env.example
# ============================================================================

# ── GPU ─────────────────────────────────────────────────────────────────────
CUDA_VISIBLE_DEVICES=0,1,2

# ── Server HTTP/Socket.IO ───────────────────────────────────────────────────
PROCESSING_SERVER_PORT=5001

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:parola_sigura@127.0.0.1:5433/licenta_db

# ── MinIO S3 Storage ─────────────────────────────────────────────────────────
MINIO_ENDPOINT=127.0.0.1:19000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=parola_sigura
MINIO_BUCKET=licenta-videos
MINIO_SECURE=0

# ── Models (relative to processing_server/) ─────────────────────────────────
MODEL_PATH=models/yolo11m_smallperson_aerial_1280.engine

# ── Tracking / Re-ID multi-camera ────────────────────────────────────────────
REID_DETECTOR_MODEL=yolo11n.pt
REID_SYNC_CAMERAS=0
REID_PROCESS_FRAME_EVERY=3
REID_YOLO_IMG_SIZE=640
REID_CONF_THRESHOLD=0.25
REID_EMIT_FRAME_EVERY=2
REID_JPEG_QUALITY=35
REID_SEND_FRAME_MAX_WIDTH=700
ENABLE_REID_EMBEDDINGS=1
REID_FRAME_SKIP=45
REID_MAX_EMBEDDINGS=3
REID_MIN_EMBEDDINGS_TO_MATCH=2
REID_RECHECK_INTERVAL=15.0
USE_SEGMENTATION_FOR_REID=1
TRACKING_PRELOAD_MAX_GPUS=1

# ── Diverse ──────────────────────────────────────────────────────────────────
KEEP_REID_CACHE=1
